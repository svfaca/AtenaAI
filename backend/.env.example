# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores

# OpenAI API Key - Obtenha em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Chave secreta para JWT - Gere uma chave aleatória segura
SECRET_KEY=your-super-secret-key-change-this-in-production

# Algoritmo de criptografia JWT
ALGORITHM=HS256

# Tempo de expiração do token em minutos
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database URL (SQLite por padrão)
DATABASE_URL=sqlite:///./app.db

# CORS Origins (separe com vírgulas se múltiplos)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
